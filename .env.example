# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side keys (NUNCA expongas estos al cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pulse-only role (lectura/escritura solo schema pulse, NO core)
SUPABASE_PULSE_ROLE_KEY=your-pulse-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email transactional (opcional · sin esto los emails se omiten con warning, todo lo demás funciona)
# Setup: crear cuenta en https://resend.com, verificar dominio dovo.app
# (agregar DKIM/SPF/DMARC en DNS), generar API key.
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=dovo <hola@dovo.app>
