# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp — vía CallMeBot (self-notifications, sin Meta Business setup)
# La API key es per-user, se guarda en profiles.callmebot_api_key vía /preferences.
# Cada user hace one-time setup: agrega +34 644 51 65 76, manda
# "I allow callmebot to send me messages" → recibe su key personal.
# Cero envvars globales necesarias.

# App secrets
CRON_SECRET=generate-with-openssl-rand-hex-32
SECRET_LINK_SLUG=dovo-xyz123
# PIN de 6 dígitos para rutas sensibles (fotos, peso). Opcional pero recomendado.
APP_PIN=

# Frontend self-reference (replan-meals fire-and-forget)
NEXT_PUBLIC_APP_URL=http://localhost:3000
